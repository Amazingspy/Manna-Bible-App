{
  "expo": {
    "name": "Manna-Bible-App",
    "slug": "Manna-Bible-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-gold.png",
    "scheme": "mannabibleapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B365C",
        "foregroundImage": "./assets/images/logo-gold.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/logo-gold.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.alex7358.MannaBibleApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B365C",
          "image": "./assets/images/logo-gold.png",
          "android": {
            "image": "./assets/images/logo-gold.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "expo-localization"
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "root": "src/app"
      },
      "eas": {
        "projectId": "27f6eed5-4b72-4c25-8564-35abe61e6467"
      }
    }
  }
}